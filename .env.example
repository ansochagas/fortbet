VITE_SNAPSHOT_URL=local:mock-backend
VITE_SNAPSHOT_TOKEN=fortbet-dev-token-1f3b8a7d0c6a4f2e
VITE_ENABLE_DEBUG=0

# Frontend: URL do backend comercial (ex.: http://localhost:8787/api/comercial)
VITE_COMERCIAL_API_URL=
# Frontend token (deve ser igual ao COMERCIAL_API_TOKEN no backend)
VITE_COMERCIAL_API_TOKEN=

# Backend comercial (node ./server/comercial-backend.mjs)
# Render define PORT automaticamente
# PORT=10000
# COMERCIAL_PORT=8787
# COMERCIAL_HOST=0.0.0.0
# COMERCIAL_API_BASE=/api/comercial
# COMERCIAL_DB_PATH=server/data/comercial-db.json
# COMERCIAL_SYNC_INTERVAL_MINUTES=30
# COMERCIAL_SYNC_TIMEZONE=America/Fortaleza
# COMERCIAL_SYNC_ON_STARTUP=1
# COMERCIAL_BOOTSTRAP_BASELINE=1
# COMERCIAL_CORS_ORIGIN=http://localhost:5173
# COMERCIAL_API_TOKEN=troque-este-token

# Sistema Monaco
# MONACO_BASE_URL=https://monacoloterias.ddns.net
# MONACO_LOGIN=seu_login
# MONACO_SENHA=sua_senha

# Mapeamento de area para colaborador (aceita codigo "00" ou nome "FORTALEZA")
# COMERCIAL_AREA_OWNERS_JSON={"00":"Bruninho","00 Bruninho":"Bruninho","00 Bruno":"Bruninho","02":"Dije","02 Dije":"Dije","03":"Anderson","04":"Neutel","04 Chefe":"Neutel","04 Neutel":"Neutel","06":"Victor","06 Torugo":"Victor","07":"Jarbas","07 Professor":"Jarbas","07 Jarbas":"Jarbas"}
